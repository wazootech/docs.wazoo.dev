{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Wazoo Docs",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "favicon": "/images/wazoo.svg",
  "colors": {
    "primary": "#FF9800",
    "light": "#FFB74D",
    "dark": "#F57C00"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "body": {
      "family": "Geist"
    }
  },
  "background": {
    "color": {
      "light": "#fafaf9",
      "dark": "#040404"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Wazoo Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  },
  "api": {
    "params": {
      "expanded": "all"
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech"
      },
      {
        "label": "Website",
        "href": "https://wazoo.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Talk to the team",
      "href": "https://etok.me/meet"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Welcome",
        "pages": [
          "introduction",
          "what-were-building",
          "projects",
          "quickstart",
          "platform",
          "manifesto"
        ]
      },
      {
        "group": "Projects",
        "pages": [
          "projects/worlds",
          "projects/wiki",
          "projects/wiki/templates/index",
          "projects/linked-markdown",
          "projects/memsdk"
        ]
      },
      {
        "group": "Worlds",
        "pages": [
          "worlds/index",
          "worlds/search",
          "worlds/query",
          "worlds/update"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/ai-sdk",
          "integrations/claude-code",
          "integrations/gemini-api",
          "integrations/mastra",
          "integrations/n8n",
          "integrations/openclaw",
          "integrations/opencode",
          "integrations/openai",
          "integrations/zapier",
          "integrations/zo"
        ]
      },
      {
        "group": "Open source",
        "pages": [
          "contribute/architecture",
          "contribute/style",
          "contribute/security",
          "contribute/self-host"
        ]
      },
      {
        "group": "Worlds API",
        "openapi": "openapi.yaml",
        "pages": [
          "GET /worlds",
          "POST /worlds",
          "GET /worlds/{slug}",
          "PUT /worlds/{slug}",
          "DELETE /worlds/{slug}",
          "POST /worlds/{slug}/export",
          "POST /worlds/{slug}/import",
          "POST /worlds/sparql",
          "POST /worlds/{slug}/sparql",
          "POST /worlds/search",
          "POST /worlds/{slug}/search",
          "GET /namespaces/{namespace}/worlds",
          "POST /namespaces/{namespace}/worlds",
          "GET /namespaces/{namespace}/worlds/{slug}",
          "PUT /namespaces/{namespace}/worlds/{slug}",
          "DELETE /namespaces/{namespace}/worlds/{slug}",
          "POST /namespaces/{namespace}/worlds/{slug}/export",
          "POST /namespaces/{namespace}/worlds/{slug}/import",
          "POST /namespaces/{namespace}/worlds/sparql",
          "POST /namespaces/{namespace}/worlds/{slug}/sparql",
          "POST /namespaces/{namespace}/worlds/search",
          "POST /namespaces/{namespace}/worlds/{slug}/search"
        ]
      },
      {
        "group": "Worlds CLI reference",
        "icon": "book-open",
        "pages": [
          "reference/cli/create",
          "reference/cli/get",
          "reference/cli/list",
          "reference/cli/update",
          "reference/cli/import",
          "reference/cli/export",
          "reference/cli/search",
          "reference/cli/sparql",
          "reference/cli/delete",
          "reference/cli/chat"
        ]
      }
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Projects",
        "items": [
          {
            "label": "Worlds",
            "href": "/projects/worlds"
          },
          {
            "label": "Wiki",
            "href": "/projects/wiki"
          },
          {
            "label": "Linked Markdown",
            "href": "/projects/linked-markdown"
          },
          {
            "label": "MemSDK",
            "href": "/projects/memsdk"
          }
        ]
      },
      {
        "header": "Worlds",
        "items": [
          {
            "label": "Worlds Console",
            "href": "https://console.wazoo.dev"
          },
          {
            "label": "API reference",
            "href": "/reference"
          },
          {
            "label": "Worlds CLI reference",
            "href": "/reference/cli"
          },
          {
            "label": "TypeScript reference",
            "href": "https://jsr.io/@worlds/client"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/wazootech"
          },
          {
            "label": "Website",
            "href": "https://wazoo.dev"
          },
          {
            "label": "X/Twitter",
            "href": "https://x.com/wazootech"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/introduction"
    },
    {
      "source": "/wiki/:slug*",
      "destination": "/projects/wiki/:slug*"
    }
  ],
  "icons": {
    "library": "lucide"
  }
}
